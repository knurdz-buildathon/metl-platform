# Metl Platform .env -- NOT for production. See metl-ops/.env.example
# This file is used by docker-compose.dev.yml locally

POSTGRES_USER=metl
POSTGRES_PASSWORD=metl_password
POSTGRES_DB=metl
REDIS_HOST=redis
NATS_URL=nats://nats:4222
VAULT_KEY=changeme
SONARQUBE_TOKEN=changeme_sonarqube_token
SONARQUBE_URL=http://sonarqube:9000
SONARQUBE_ADMIN_PASSWORD=changeme_sonar_admin

# ============================================
# Microsoft AI Foundry (Primary — multiple endpoints for failover)
# Supports: GPT-4o, GLM-4, KimiK, DeepSeek, Grok
# ============================================
AI_FOUNDRY_ENDPOINT_1=
AI_FOUNDRY_KEY_1=
AI_FOUNDRY_MODEL_1=gpt-4o

AI_FOUNDRY_ENDPOINT_2=
AI_FOUNDRY_KEY_2=
AI_FOUNDRY_MODEL_2=glm-4

AI_FOUNDRY_ENDPOINT_3=
AI_FOUNDRY_KEY_3=
AI_FOUNDRY_MODEL_3=kimi

AI_FOUNDRY_ENDPOINT_4=
AI_FOUNDRY_KEY_4=
AI_FOUNDRY_MODEL_4=deepseek-chat

AI_FOUNDRY_ENDPOINT_5=
AI_FOUNDRY_KEY_5=
AI_FOUNDRY_MODEL_5=grok

# ============================================
# Gemini Fallback
# ============================================
GEMINI_API_KEY=changeme_gemini

# ============================================
# OpenAI Last-Resort Fallback
# ============================================
OPENAI_API_KEY=changeme_openai
OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================
# Cursor SDK Cloud Agents (Primary vibe-coding engine)
# Multiple API keys for failover
# ============================================
CURSOR_API_KEY_1=changeme_cursor_1
CURSOR_API_KEY_2=
CURSOR_API_KEY_3=
