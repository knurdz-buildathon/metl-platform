generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid())
  name        String
  slug        String   @unique
  email       String
  clusterTier String   @default("warm") @map("cluster_tier")
  plan        String   @default("free") @map("plan")
  maxProjects Int      @default(1) @map("max_projects")
  maxMemoryMb Int      @default(512) @map("max_memory_mb")
  allowEjection       Boolean @default(false) @map("allow_ejection")
  allowAdvancedGlassBox Boolean @default(false) @map("allow_advanced_glassbox")
  allowMeteredBilling Boolean @default(false) @map("allow_metered_billing")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  providerMatrix ProviderMatrix?
  deployments    Deployment[]
  resources      Resource[]
  incidents      Incident[]
  tasks          Task[]
  users          User[]
  subscriptions  Subscription[]
  usageEvents    UsageEvent[]

  @@map("tenants")
}

model ProviderMatrix {
  id     String @id @default(uuid())
  tenantId String @unique @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  databaseMode String  @map("database_mode")
  databaseConfig Json? @map("database_config")
  
  storageMode String @map("storage_mode")
  storageConfig Json? @map("storage_config")
  
  mailMode String @map("mail_mode")
  mailConfig Json? @map("mail_config")
  
  monitoringMode String @map("monitoring_mode")
  monitoringConfig Json? @map("monitoring_config")
  
  authMode String @map("auth_mode")
  authConfig Json? @map("auth_config")
  
  hostingMode String @map("hosting_mode")
  hostingConfig Json? @map("hosting_config")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("provider_matrices")
}

model Deployment {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name          String
  slug          String
  gitUrl        String   @map("git_url")
  branch        String   @default("main")
  status        String   @default("pending")
  imageTag      String?  @map("image_tag")
  containerPort Int      @default(3000) @map("container_port")
  scalingTier   String   @default("warm") @map("scaling_tier")
  memoryLimitMb Int      @default(512) @map("memory_limit_mb")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  resources Resource[]
  tasks     Task[]
  incidents Incident[]

  @@unique([tenantId, slug])
  @@map("deployments")
}

model Resource {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  deploymentId String?     @map("deployment_id")
  deployment   Deployment? @relation(fields: [deploymentId], references: [id], onDelete: SetNull)
  
  type     String
  mode     String
  status   String   @default("provisioning")
  credentials Json?
  endpoint String?
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("resources")
}

model Task {
  id     String @id @default(uuid())
  type   String
  status String @default("pending")
  
  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  deploymentId String?     @map("deployment_id")
  deployment   Deployment? @relation(fields: [deploymentId], references: [id], onDelete: SetNull)
  
  payload Json
  result  Json?
  error   String?
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tasks")
}

model Incident {
  id     String @id @default(uuid())
  
  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  deploymentId String?     @map("deployment_id")
  deployment   Deployment? @relation(fields: [deploymentId], references: [id], onDelete: SetNull)
  
  severity    String
  category    String
  message     String
  source      String
  resolvedAt  DateTime?   @map("resolved_at")
  
  createdAt DateTime @default(now()) @map("created_at")

  @@map("incidents")
}

model ChatMessage {
  id     String @id @default(uuid())
  
  tenantId String @map("tenant_id")
  role     String
  content  String
  metadata Json?
  
  createdAt DateTime @default(now()) @map("created_at")

  @@map("chat_messages")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  emailVerified Boolean   @default(false) @map("email_verified")
  name          String?
  avatarUrl     String?   @map("avatar_url")
  passwordHash  String?   @map("password_hash")
  googleId      String?   @unique @map("google_id")
  githubId      String?   @unique @map("github_id")
  role          String    @default("user")
  tenantId      String    @map("tenant_id")
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  subscriptions Subscription[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model Subscription {
  id                  String    @id @default(uuid())
  userId              String    @map("user_id")
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId            String    @map("tenant_id")
  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dodoCustomerId      String?   @map("dodo_customer_id")
  dodoSubscriptionId  String?   @unique @map("dodo_subscription_id")
  plan                String    @default("free")
  status              String    @default("active")
  currentPeriodEnd    DateTime? @map("current_period_end")
  cancelAtPeriodEnd   Boolean   @default(false) @map("cancel_at_period_end")
  canceledAt          DateTime? @map("canceled_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@map("subscriptions")
}

model UsageEvent {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  eventType   String   @map("event_type")
  eventName   String   @map("event_name")
  quantity    Int      @default(1)
  metadata    Json?
  syncedToDodo Boolean @default(false) @map("synced_to_dodo")
  dodoEventId String?  @map("dodo_event_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([tenantId, eventName, createdAt])
  @@map("usage_events")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("password_reset_tokens")
}
