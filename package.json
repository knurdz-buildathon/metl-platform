{
  "name": "metl-platform",
  "version": "1.0.0",
  "description": "Metl - Open Agentic Cloud Fabric",
  "private": true,
  "workspaces": [
    "shared/*",
    "services/*",
    "agents/*",
    "ejection-engine",
    "cli",
    "frontend"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "docker-compose -f docker-compose.dev.yml up -d",
    "dev:down": "docker-compose -f docker-compose.dev.yml down",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "jest"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.5",
    "eslint": "^9.0.0",
    "jest": "^29.0.0",
    "tsx": "^4.10.5"
  }
}
